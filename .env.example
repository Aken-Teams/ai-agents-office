# Server
PORT=12054
JWT_SECRET=change-this-to-a-secure-random-string
NODE_ENV=development

# CORS (comma-separated origins, defaults to localhost:PORT-1 and localhost:PORT)
# CORS_ORIGINS=http://localhost:12053,http://localhost:12054

# API URL for Next.js proxy (defaults to http://localhost:PORT)
# API_URL=http://localhost:12054

# Workspace (sandbox root for generated files)
WORKSPACE_ROOT=./workspace

# Claude CLI
CLAUDE_CLI_PATH=claude

# Deploy mode: pro-panjit (internal, uniform quota) | pro-out (external, per-user quota)
DEPLOY_MODE=pro-panjit

# Storage quota per user (GB)
STORAGE_QUOTA_GB=2

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=db_ai_agents
MYSQL_USER=root
MYSQL_PASSWORD=

# ----------------------------------------
# Resend 寄信設定 (HTTP API，不受 SMTP port 限制)
# ----------------------------------------
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_BCC=


DEEPSEEK_API_KEY=